# ============================================================
#  VOLTAGE — .env.example
#  Rename this file to .env for local development.
#
#  These values must be manually copied into config.js
#  because browsers cannot read .env files directly.
# ============================================================

# AI provider settings
# Public deployment: set AI_PROXY_URL to your Cloudflare Worker URL.
# Local development: keep AI_PROXY_URL empty and use AI_API_KEY in config.local.js.
AI_PROXY_URL=https://your-worker.your-subdomain.workers.dev
AI_API_KEY=your_groq_api_key_here
AI_MODEL=llama-3.3-70b-versatile

# Firebase project config — from Firebase Console > Project Settings
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789
FIREBASE_APP_ID=1:123456789:web:abcdef
FIREBASE_DATABASE_ID=your_firestore_database_id
